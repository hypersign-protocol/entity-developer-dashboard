    }, {
      "id": "6fd1911c-d86f-4aa9-a2bf-352fae7c76ec",
      "comment": "",
      "command": "executeScript",
      "target": "document.querySelector('.logo-upload-wrapper input[type=\"file\"]').classList.remove('d-none');",
      "targets": [],
      "value": ""
    }, {
      "id": "8cf00e0d-7e45-4844-87e7-2580e6622106",
      "comment": "",
      "command": "executeScript",
      "target": "var input = document.querySelector('.logo-upload-wrapper input[type=\"file\"]');  var file = new File([\"dummy content\"], \"logo.png\", { type: \"image/png\" }); var dataTransfer = new DataTransfer(); dataTransfer.items.add(file);  input.files = dataTransfer.files; input.dispatchEvent(new Event('change', { bubbles: true }));",
      "targets": [],
      "value": ""
    }, {
      "id": "7f107271-d891-4c24-8d7c-4770114b310f",
      "comment": "",
      "command": "executeScript",
      "target": "document.querySelector('.logo-upload-wrapper input[type=\"file\"]').style.display = 'block'",
      "targets": [],
      "value": ""
    }, {
      "id": "f530bb37-0011-4946-b1df-d99041b1bec6",
      "comment": "",
      "command": "executeScript",
      "target": "var imageUrl=${companyLogo};var wrapper=document.querySelector('.logo-upload-wrapper');if(wrapper){fetch(imageUrl).then(res=>res.blob()).then(blob=>{var file=new File([blob],\"logo.png\",{type:blob.type});var dt=new DataTransfer();dt.items.add(file);var input=document.querySelector('.logo-upload-wrapper input[type=\\\"file\\\"]');if(input){input.files=dt.files;input.dispatchEvent(new Event('change',{bubbles:true}));}}).catch(e=>console.error(e));}",
      "targets": [],
